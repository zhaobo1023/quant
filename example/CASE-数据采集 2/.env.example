# ===== 交易团队配置 =====
# 复制此文件为 .env 并填入你的实际配置

# ----- 数据库配置 -----
WUCAI_SQL_HOST=localhost
WUCAI_SQL_USERNAME=root
WUCAI_SQL_PASSWORD=your_password
WUCAI_SQL_PORT=3306
WUCAI_SQL_DB=wucai_trade

# ----- Kimi API -----
KIMI_API_KEY=your_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-latest

# ----- DashScope/Qwen -----
DASHSCOPE_API_KEY=your_api_key
QWEN_MODEL=qwen-flash

# ----- miniQMT 配置 -----
# QMT安装路径（userdata_mini目录）
QMT_PATH=D:\光大证券金阳光QMT实盘\userdata_mini

# 资金账号
QMT_ACCOUNT_ID=your_account_id

# 运行模式: live(实盘) / simulation(模拟)
QMT_MODE=live
